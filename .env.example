# ============================================================
# AKT Institute OS — Environment Variables Template
# Copy this to .env and fill in all values.
# NEVER commit .env to git.
# ============================================================

# ── Database ──────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=akt_institute
DB_USER=akt_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ───────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME

# ── Meilisearch ───────────────────────────────────────────────
# Generate: openssl rand -hex 32
MEILI_MASTER_KEY=CHANGE_ME

# ── Spring ────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
# Multi-institute: include all subdomain origins + apex domain, comma-separated
CORS_ALLOWED_ORIGINS=https://akinfoinstitute.tech,https://delhi.akinfoinstitute.tech,https://patna.akinfoinstitute.tech

# ── Email (Gmail App Password) ────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=16_CHAR_APP_PASSWORD

# ── Notifications ─────────────────────────────────────────────
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_FROM_NAME=AKT Info Institute
NOTIFICATION_WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=META
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
